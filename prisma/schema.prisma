generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   // "CLIENT" or "FREELANCER"
  bio       String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks          Task[]
  skills         FreelancerSkill[]
  applications   Application[]
  invitationsReceived Invitation[] @relation("ReceivedInvitations")
  invitationsSent     Invitation[] @relation("SentInvitations")
  reviewsGiven        Review[]     @relation("ReviewsGiven")
  reviewsReceived     Review[]     @relation("ReviewsReceived")
  portfolios     Portfolio[]
  matchScores    MatchScore[]
}

model Skill {
  id          String   @id @default(cuid())
  skillName   String
  category    String?

  freelancerSkills FreelancerSkill[]
  taskSkills       TaskSkill[]
}

model Task {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  description String
  budgetMin   Float?
  budgetMax   Float?
  deadline    DateTime?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  client       User          @relation(fields: [clientId], references: [id])
  taskSkills   TaskSkill[]
  applications Application[]
  invitations  Invitation[]
  reviews      Review[]
  matchScores  MatchScore[]
}

model FreelancerSkill {
  id               String @id @default(cuid())
  userId           String
  skillId          String
  proficiencyLevel Int?
  experienceYears  Int?

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model TaskSkill {
  id            String @id @default(cuid())
  taskId        String
  skillId       String
  requiredLevel Int?

  task  Task  @relation(fields: [taskId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([taskId, skillId])
}

model Application {
  id             String   @id @default(cuid())
  taskId         String
  freelancerId   String
  proposalText   String?
  bidAmount      Float?
  estimatedDays  Int?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id])
  freelancer User @relation(fields: [freelancerId], references: [id])
}

model Invitation {
  id           String   @id @default(cuid())
  taskId       String
  clientId     String
  freelancerId String
  message      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id])
  client     User @relation("SentInvitations", fields: [clientId], references: [id])
  freelancer User @relation("ReceivedInvitations", fields: [freelancerId], references: [id])
}

model Review {
  id           String   @id @default(cuid())
  taskId       String
  clientId     String
  freelancerId String
  rating       Int?
  comment      String?
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id])
  client     User @relation("ReviewsGiven", fields: [clientId], references: [id])
  freelancer User @relation("ReviewsReceived", fields: [freelancerId], references: [id])
}

model MatchScore {
  id                  String   @id @default(cuid())
  taskId              String
  freelancerId        String
  score               Float?
  matchedSkillsCount  Int?
  totalRequiredSkills Int?
  createdAt           DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id])
  freelancer User @relation(fields: [freelancerId], references: [id])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  projectLink String?
  githubLink  String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
